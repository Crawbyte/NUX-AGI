{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_your-token-here"
      }
    },
    "google-calendar": {
      "command": "npx",
      "args": ["-y", "@cocal/google-calendar-mcp"],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "/path/to/.mcp-auth/gcp-oauth.keys.json"
      }
    },
    "gmail": {
      "command": "npx",
      "args": ["-y", "@gongrzhe/server-gmail-autoauth-mcp"],
      "env": {
        "GMAIL_OAUTH_PATH": "/path/to/.mcp-auth/gcp-oauth.keys.json",
        "GMAIL_CREDENTIALS_PATH": "/path/to/.mcp-auth/gmail-credentials.json"
      }
    },
    "google-drive": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gdrive"],
      "env": {
        "GDRIVE_OAUTH_PATH": "/path/to/.mcp-auth/gcp-oauth.keys.json",
        "GDRIVE_CREDENTIALS_PATH": "/path/to/.mcp-auth/gdrive-credentials.json"
      }
    }
  }
}
